# =====================================================================
# HSO AI — Environment Configuration
#
# Copy this file to .env.local and fill in real values.
# DO NOT COMMIT .env.local — it contains secrets.
# =====================================================================

# ---------------------------------------------------------------------
# Model providers — pick at least one
# ---------------------------------------------------------------------

# Recommended default: OpenRouter (one API key, many models)
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Alternative: Direct Anthropic API
# Get a key at https://console.anthropic.com/
# ANTHROPIC_API_KEY=

# Alternative: Direct OpenAI API
# Get a key at https://platform.openai.com/api-keys
# OPENAI_API_KEY=

# ---------------------------------------------------------------------
# Model selection — change models here without touching code
# Format: <provider>:<model_id>
#
# Provider must be one of: openrouter, anthropic, openai
# (Or add a new provider in shared/model_gateway.py)
# ---------------------------------------------------------------------

# Cheap, fast model for classification tasks
HSO_MODEL_CLASSIFIER=openrouter:anthropic/claude-haiku-4.5

# Capable model for content drafting
HSO_MODEL_DRAFTER=openrouter:anthropic/claude-sonnet-4.6

# For multi-step research tasks (e.g. grant agent)
HSO_MODEL_RESEARCHER=openrouter:anthropic/claude-sonnet-4.6

# For high-stakes long-form writing (e.g. grant applications)
HSO_MODEL_WRITER=openrouter:anthropic/claude-opus-4.7

# Examples of alternative configurations (comment out the above):
#
# Use GPT-4 across the board:
#   HSO_MODEL_CLASSIFIER=openrouter:openai/gpt-4o-mini
#   HSO_MODEL_DRAFTER=openrouter:openai/gpt-4o
#
# Use Gemini:
#   HSO_MODEL_CLASSIFIER=openrouter:google/gemini-flash-1.5
#   HSO_MODEL_DRAFTER=openrouter:google/gemini-pro-1.5
#
# Cheaper open-source via OpenRouter:
#   HSO_MODEL_DRAFTER=openrouter:meta-llama/llama-3.1-70b-instruct

# ---------------------------------------------------------------------
# Knowledge base
# ---------------------------------------------------------------------

# Path to the kb folder, relative to where the webhook server runs
HSO_KB_PATH=./kb

# ---------------------------------------------------------------------
# Email agent configuration
# ---------------------------------------------------------------------

# Donations equal to or above this amount in NOK escalate to a human.
# 5000 NOK is a reasonable default; HSO leadership should confirm.
HSO_DONATION_THRESHOLD_NOK=5000

# ---------------------------------------------------------------------
# Webhook server
# ---------------------------------------------------------------------

# A long random string used to authenticate Make.com / n8n calls to the
# webhook. Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
HSO_WEBHOOK_SECRET=

# Port the webhook listens on (Render/Fly typically set this for you).
PORT=8080

# Polite header for OpenRouter usage analytics
HSO_APP_URL=https://hopespot.no
